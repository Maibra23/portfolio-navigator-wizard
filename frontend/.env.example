# =============================================================================
# Portfolio Navigator Wizard - Frontend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# Prefix all variables with VITE_ so Vite can expose them to the frontend

# -----------------------------------------------------------------------------
# BACKEND API URL (Required for production)
# -----------------------------------------------------------------------------

# Backend API base URL
# Leave empty for development (uses Vite proxy to http://127.0.0.1:8000)
# For production (Railway), set to your backend URL
# Example: https://portfolio-backend-production.up.railway.app
VITE_API_BASE_URL=

# -----------------------------------------------------------------------------
# ENVIRONMENT
# -----------------------------------------------------------------------------

# Environment name (optional)
# Options: development, staging, production
VITE_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# ADMIN API (Optional - for warm-tickers to succeed)
# -----------------------------------------------------------------------------
# Set to the same value as backend ADMIN_API_KEY so warm-tickers requests are authorized.
# Leave empty if you do not need client-side cache warming (backend may still return 401/503).
VITE_ADMIN_API_KEY=

# -----------------------------------------------------------------------------
# RAILWAY-SPECIFIC (Auto-configured)
# -----------------------------------------------------------------------------

# Railway will automatically inject these in production:
# VITE_API_BASE_URL will be set in Railway dashboard variables
# pointing to your backend service URL

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# 1. Copy this file to .env.local: cp .env.example .env.local
# 2. For local development, leave VITE_API_BASE_URL empty
# 3. For production on Railway:
#    - Go to frontend service → Variables
#    - Set VITE_API_BASE_URL=https://your-backend-url.up.railway.app
# 4. All Vite environment variables must start with VITE_ to be exposed
# 5. Never commit .env.local to git (already in .gitignore)
