# ==============================================================================
# Portfolio Navigator Wizard - Environment Configuration Template
# ==============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control (it's in .gitignore)
# ==============================================================================

# ------------------------------------------------------------------------------
# Environment Configuration
# ------------------------------------------------------------------------------
# Options: development, production
ENVIRONMENT=development

# ------------------------------------------------------------------------------
# API Keys
# ------------------------------------------------------------------------------
# REQUIRED: Alpha Vantage API Key
# Get your free key at: https://www.alphavantage.co/support/#api-key
# Free tier: 5 API calls per minute, 500 calls per day
# Paid tiers: Higher limits available
ALPHA_VANTAGE_API_KEY=your_key_here

# Optional: Fallback API key (used if primary key fails)
# ALPHA_VANTAGE_FALLBACK_KEY=demo

# ------------------------------------------------------------------------------
# Data Settings
# ------------------------------------------------------------------------------
# Use live data (current date) or fixed historical date
# Options: true, false
# When false: Uses fixed end date of 2025-06-01 for consistent testing
# When true: Uses current date (requires live API access)
USE_LIVE_DATA=false

# Use pre-validated master ticker list
# Options: true, false
# When true: Uses only tickers confirmed to work with Yahoo Finance
# When false: Uses full master list with normalization
USE_VALIDATED_MASTER_LIST=false

# ------------------------------------------------------------------------------
# Cache Settings
# ------------------------------------------------------------------------------
# Maximum number of tickers to cache in memory
# Default: 100
CACHE_MAX_SIZE=100

# Cache cleanup interval in seconds
# Default: 3600 (1 hour)
CACHE_CLEANUP_INTERVAL=3600

# Cache persistence mode
# Options: memory, file
# memory: In-memory only (faster, lost on restart)
# file: Persistent to disk (slower, survives restart)
CACHE_PERSISTENCE=memory

# ------------------------------------------------------------------------------
# Logging Configuration
# ------------------------------------------------------------------------------
# Log level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# Enable debug logs (more verbose)
# Options: true, false
# Default: false
ENABLE_DEBUG_LOGS=false

# ------------------------------------------------------------------------------
# Notes
# ------------------------------------------------------------------------------
# - All boolean values should be lowercase: true or false
# - All numeric values should be integers (no decimals)
# - Environment variables are case-sensitive
# - Empty values will use defaults (if available)
# - Comments (lines starting with #) are ignored
